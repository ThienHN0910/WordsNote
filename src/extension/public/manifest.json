{
  "manifest_version": 3,
  "name": "WordsNote",
  "version": "1.1.0",
  "description": "Vocabulary learning assistant - highlight text to save words",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["http://words-note.runasp.net/*", "https://words-note.runasp.net/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
