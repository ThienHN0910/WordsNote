# MongoDB Atlas connection string (replace with your Atlas connection string)
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_CONNECTION_STRING=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority

# MongoDB database name
MONGODB_DATABASE_NAME=WordsNote

# JWT Secret Key (use a strong random key in production, minimum 256 bits)
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production

# JWT Issuer and Audience
JWT_ISSUER=WordsNote
JWT_AUDIENCE=WordsNote
