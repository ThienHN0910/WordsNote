<Window x:Class="WordsNote.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:WordsNote.Desktop.Converters"
        mc:Ignorable="d"
        Title="WordsNote Desktop (WPF)"
        Height="980"
        Width="1600"
        MinHeight="820"
        MinWidth="1280"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
    <Window.Resources>
        <SolidColorBrush x:Key="WnBg" Color="#F7F3EC" />
        <SolidColorBrush x:Key="WnSurface" Color="#FFFFFF" />
        <SolidColorBrush x:Key="WnSurfaceSoft" Color="#FFF8EF" />
        <SolidColorBrush x:Key="WnBorder" Color="#E6DFD3" />
        <SolidColorBrush x:Key="WnInk" Color="#1F2333" />
        <SolidColorBrush x:Key="WnMuted" Color="#5B6275" />
        <SolidColorBrush x:Key="WnPrimary" Color="#1F4ED8" />
        <SolidColorBrush x:Key="WnPrimarySoft" Color="#EDF2FF" />

        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBooleanConverter x:Key="InverseBool" />
        <conv:StringEqualsConverter x:Key="StringEquals" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource WnInk}" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource WnPrimary}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource WnPrimary}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,0" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource WnSurface}" />
            <Setter Property="Foreground" Value="{StaticResource WnInk}" />
            <Setter Property="BorderBrush" Value="{StaticResource WnBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource WnSurface}" />
            <Setter Property="Foreground" Value="{StaticResource WnInk}" />
            <Setter Property="BorderBrush" Value="{StaticResource WnBorder}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource WnSurface}" />
            <Setter Property="Foreground" Value="{StaticResource WnInk}" />
            <Setter Property="BorderBrush" Value="{StaticResource WnBorder}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="PlaceholderTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#94A3B8" />
            <Setter Property="Margin" Value="10,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WnBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="12" Padding="12" CornerRadius="12" BorderBrush="#D1D5DB" BorderThickness="1" Background="White">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Margin="0,0,12,0" Padding="16,7" Content="Reload Data" Click="ReloadData_Click" />

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock VerticalAlignment="Center" Margin="0,0,8,0" Text="{Binding StatusMessage}" Foreground="#334155" />
                    <TextBlock VerticalAlignment="Center" FontWeight="Bold" Foreground="#0EA5E9" Text="{Binding IsBusy, StringFormat=Busy: {0}}" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="12,0,12,12" SelectedIndex="{Binding SelectedTabIndex}">
            <TabItem Header="Landing">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20" Orientation="Vertical">
                        <TextBlock FontSize="13" Foreground="#64748B" Text="WordsNote Studio" />
                        <TextBlock Margin="0,8,0,8" FontSize="34" FontWeight="Bold" Text="Learn in a way that feels handcrafted." />
                        <TextBlock FontSize="16" Foreground="#334155" TextWrapping="Wrap" Text="Desktop app mirrors web features: Learn (Flashcards/Learn/Practice), Manage collections and cards in local/cloud mode, and bilingual Privacy policy." />

                        <Border Margin="0,20,0,0" Padding="16" CornerRadius="10" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1">
                            <StackPanel>
                                <TextBlock FontSize="20" FontWeight="SemiBold" Text="Quick Start" />
                                <TextBlock Margin="0,10,0,0" TextWrapping="Wrap" Text="1. Open Settings tab and save API Base URL + Google Client ID." />
                                <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Text="2. Use Learn tab for public read-only learning data." />
                                <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Text="3. Use Manage tab in local mode first, then login Google (browser) to sync with cloud." />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Learn">
                <Grid Margin="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Padding="12" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="10" Background="White">
                        <StackPanel>
                            <TextBlock FontSize="22" FontWeight="SemiBold" Text="Decks" />
                            <TextBlock Margin="0,4,0,10" Foreground="#475569" Text="Public dynamic collections from backend" />
                            <ListBox Height="650"
                                     ItemsSource="{Binding Decks}"
                                     SelectedItem="{Binding LearnSelectedDeck}"
                                     DisplayMemberPath="Title" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Padding="14" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="10" Background="White">
                        <StackPanel>
                            <TextBlock FontSize="26" FontWeight="Bold" Text="Learn Lab" />
                            <TextBlock Margin="0,4,0,8" Foreground="#475569" Text="Modes: Flashcards, Learn (typed answer), Practice (multiple choice)" />
                            <TextBlock FontSize="15" FontWeight="SemiBold" Text="{Binding LearnSelectedDeck.Title, StringFormat=Collection: {0}}" />

                            <StackPanel Margin="0,10,0,12" Orientation="Horizontal">
                                <Button Padding="14,6" Margin="0,0,8,0" Content="Flashcards" Click="LearnFlashMode_Click" />
                                <Button Padding="14,6" Margin="0,0,8,0" Content="Learn" Click="LearnTypeMode_Click" />
                                <Button Padding="14,6" Content="Practice" Click="LearnPracticeMode_Click" />
                            </StackPanel>

                            <Border Padding="14" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="10" Background="#F8FAFC">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Foreground="#334155" Text="{Binding LearnDisplayIndex, StringFormat=Card {0}}" />
                                    <TextBlock Foreground="#64748B" Text="{Binding LearnCardCount, StringFormat=Total cards in mode: {0}}" />

                                    <StackPanel Margin="0,12,0,0" Visibility="{Binding LearnMode, Converter={StaticResource StringEquals}, ConverterParameter=flash}">
                                        <TextBlock FontSize="26" FontWeight="Bold" TextWrapping="Wrap" Text="{Binding LearnCurrentCard.Front}" />
                                        <TextBlock Margin="0,10,0,0" FontSize="20" TextWrapping="Wrap" Foreground="#0F766E" Text="{Binding LearnCurrentCard.Back}" Visibility="{Binding LearnShowBack, Converter={StaticResource BoolToVis}}" />
                                        <TextBlock Margin="0,6,0,0" Foreground="#64748B" Text="Click Flip to reveal answer" Visibility="{Binding LearnShowBack, Converter={StaticResource InverseBool}}" />
                                        <TextBlock Margin="0,6,0,0" Foreground="#475569" Text="{Binding LearnCurrentCard.Hint, StringFormat=Hint: {0}}" />

                                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                            <Button Padding="12,6" Margin="0,0,8,0" Content="Previous" Click="LearnPrevious_Click" />
                                            <Button Padding="12,6" Margin="0,0,8,0" Content="Flip" Click="LearnFlip_Click" />
                                            <Button Padding="12,6" Content="Next" Click="LearnNext_Click" />
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Margin="0,12,0,0" Visibility="{Binding IsLearnTypingMode, Converter={StaticResource BoolToVis}}">
                                        <TextBlock FontSize="24" FontWeight="Bold" TextWrapping="Wrap" Text="{Binding LearnCurrentCard.Front}" />
                                        <Grid Margin="0,10,0,0">
                                            <TextBox x:Name="LearnTypedAnswerTextBox" Height="38" VerticalContentAlignment="Center" Text="{Binding LearnTypedAnswer, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Text="Type your answer here">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource PlaceholderTextStyle}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Text, ElementName=LearnTypedAnswerTextBox}" Value="">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                            <Button Padding="14,6" Margin="0,0,8,0" Content="Check" Click="LearnCheckTyping_Click" />
                                            <Button Padding="14,6" Content="Skip" Click="LearnNext_Click" />
                                        </StackPanel>
                                        <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" Text="{Binding LearnFeedback}" Foreground="#334155" />
                                    </StackPanel>

                                    <StackPanel Margin="0,12,0,0" Visibility="{Binding IsLearnPracticeMode, Converter={StaticResource BoolToVis}}">
                                        <TextBlock FontSize="24" FontWeight="Bold" TextWrapping="Wrap" Text="{Binding LearnCurrentCard.Front}" />
                                        <TextBlock Margin="0,8,0,4" Text="Choose the correct answer" />
                                        <ListBox Height="180" ItemsSource="{Binding LearnPracticeOptions}" SelectedItem="{Binding SelectedPracticeOption}" />
                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                            <Button Padding="14,6" Margin="0,0,8,0" Content="Submit" Click="LearnSubmitPractice_Click" />
                                            <Button Padding="14,6" Content="Next" Click="LearnNextPractice_Click" IsEnabled="{Binding LearnPracticeAwaitingNext}" />
                                        </StackPanel>
                                        <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" Text="{Binding LearnPracticeFeedback}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Privacy">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock FontSize="30" FontWeight="Bold" Text="{Binding PrivacyTitle}" />
                        <TextBlock Margin="0,6,0,12" FontSize="15" Foreground="#475569" TextWrapping="Wrap" Text="{Binding PrivacySubtitle}" />

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Button Padding="12,6" Margin="0,0,8,0" Content="VI" Click="PrivacyVi_Click" />
                            <Button Padding="12,6" Content="EN" Click="PrivacyEn_Click" />
                        </StackPanel>

                        <TextBox Height="620"
                                 FontSize="14"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding PrivacyPolicyText, Mode=OneWay}" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Manage">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="12" Margin="0,0,0,10" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="10" Background="#FFF8EF">
                        <StackPanel>
                            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Manage Workspace" />
                            <TextBlock Margin="0,4,0,8" Foreground="#475569" Text="{Binding ManageModeLabel}" />
                            <TextBlock Margin="0,0,0,8" Foreground="#334155" TextWrapping="Wrap" Text="Khi chưa login: thao tác chỉ lưu local trên máy. Khi login Google: thao tác đi cloud. Có cả Sync Local -> Cloud và Sync Cloud -> Local như extension." />

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Button Padding="14,6" Margin="0,0,8,0" Content="Sync Cloud -> Local" Click="SyncCloudToLocal_Click" />
                                <TextBlock VerticalAlignment="Center" Foreground="#475569" Text="Load cloud data and save into local storage" />
                            </StackPanel>

                            <StackPanel Visibility="{Binding IsNotAuthenticated, Converter={StaticResource BoolToVis}}">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button Padding="14,6" Content="Login Google (Browser)" Click="LoginWithGoogleBrowser_Click" />
                                    <TextBlock VerticalAlignment="Center" Margin="8,0,0,0" Foreground="#475569" Text="Use Google Client ID from Settings tab" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal">
                                    <Grid Width="520" Margin="0,0,8,0">
                                        <TextBox x:Name="GoogleIdTokenTextBox" Height="36" VerticalContentAlignment="Center" Text="{Binding GoogleIdToken, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="Paste Google ID Token (optional fallback)">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource PlaceholderTextStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=GoogleIdTokenTextBox}" Value="">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                    <Button Padding="14,6" Content="Login Google (ID Token)" Click="LoginWithGoogleToken_Click" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVis}}">
                                <Button Padding="14,6" Margin="0,0,8,0" Content="Sync Local -> Cloud" Click="SyncLocalToCloud_Click" IsEnabled="{Binding CanSyncLocalToCloud}" />
                                <Button Padding="14,6" Margin="0,0,8,0" Content="Logout Google" Click="Logout_Click" />
                                <TextBlock VerticalAlignment="Center" Foreground="#475569" Text="{Binding LastSyncMessage}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="340" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Padding="12" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="10" Background="White">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock FontSize="22" FontWeight="SemiBold" Text="Create Collection" />
                                    <Grid Margin="0,8,0,8">
                                        <TextBox x:Name="NewCollectionTitleTextBox" Height="36" Text="{Binding NewCollectionTitle, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="Collection title">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource PlaceholderTextStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=NewCollectionTitleTextBox}" Value="">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                    <Grid Margin="0,0,0,10">
                                        <TextBox x:Name="NewCollectionDescriptionTextBox" Height="70" TextWrapping="Wrap" AcceptsReturn="True" Text="{Binding NewCollectionDescription, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="Collection description" VerticalAlignment="Top" Margin="10,8,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource PlaceholderTextStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=NewCollectionDescriptionTextBox}" Value="">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                    <Button Padding="12,7" Content="Create" Click="CreateCollection_Click" />

                                    <Separator Margin="0,14,0,12" />

                                    <TextBlock FontSize="22" FontWeight="SemiBold" Text="Your Collections" />
                                    <Grid Margin="0,8,0,8">
                                        <TextBox x:Name="ManageCollectionQueryTextBox" Height="34" Text="{Binding ManageCollectionQuery, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="Search collections">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource PlaceholderTextStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=ManageCollectionQueryTextBox}" Value="">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                    <ComboBox Margin="0,0,0,10" SelectedValuePath="Tag" SelectedValue="{Binding ManageCollectionSort, UpdateSourceTrigger=PropertyChanged}">
                                        <ComboBoxItem Tag="recent" Content="Recently updated" />
                                        <ComboBoxItem Tag="title" Content="Title A-Z" />
                                        <ComboBoxItem Tag="cards" Content="Most cards" />
                                    </ComboBox>

                                    <ListBox Height="510" ItemsSource="{Binding FilteredManageDecks}" SelectedItem="{Binding ManageSelectedDeck}" DisplayMemberPath="Title" />
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <Border Grid.Column="2" Padding="12" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="10" Background="White">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock FontSize="26" FontWeight="Bold" Text="{Binding ManageSelectedDeck.Title}" />
                                    <TextBlock Margin="0,4,0,8" Foreground="#475569" TextWrapping="Wrap" Text="{Binding ManageSelectedDeck.Description}" />

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Button Padding="12,6" Margin="0,0,8,0" Content="Edit Collection" Click="StartCollectionEdit_Click" />
                                        <Button Padding="12,6" Content="Delete Collection" Click="DeleteCollection_Click" />
                                    </StackPanel>

                                    <Border Padding="10" Margin="0,0,0,10" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Visibility="{Binding IsEditingCollection, Converter={StaticResource BoolToVis}}">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="Edit Collection" />
                                            <Grid Margin="0,8,0,8">
                                                <TextBox x:Name="EditCollectionTitleTextBox" Height="34" Text="{Binding EditCollectionTitle, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Text="Edit collection title">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource PlaceholderTextStyle}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Text, ElementName=EditCollectionTitleTextBox}" Value="">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                            <Grid Margin="0,0,0,10">
                                                <TextBox x:Name="EditCollectionDescriptionTextBox" Height="66" TextWrapping="Wrap" AcceptsReturn="True" Text="{Binding EditCollectionDescription, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Text="Edit collection description" VerticalAlignment="Top" Margin="10,8,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource PlaceholderTextStyle}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Text, ElementName=EditCollectionDescriptionTextBox}" Value="">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Padding="12,6" Margin="0,0,8,0" Content="Save" Click="SaveCollectionEdit_Click" />
                                                <Button Padding="12,6" Content="Cancel" Click="CancelCollectionEdit_Click" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <WrapPanel Margin="0,0,0,10">
                                        <Border Width="170" Margin="0,0,8,0" Padding="8" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Background="#F8FAFC">
                                            <StackPanel>
                                                <TextBlock Foreground="#475569" Text="Total cards" />
                                                <TextBlock FontSize="24" FontWeight="Bold" Text="{Binding ManageTotalCards}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Width="170" Margin="0,0,8,0" Padding="8" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Background="#F8FAFC">
                                            <StackPanel>
                                                <TextBlock Foreground="#475569" Text="Due now" />
                                                <TextBlock FontSize="24" FontWeight="Bold" Text="{Binding ManageDueCards}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Width="170" Padding="8" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Background="#F8FAFC">
                                            <StackPanel>
                                                <TextBlock Foreground="#475569" Text="Mastered" />
                                                <TextBlock FontSize="24" FontWeight="Bold" Text="{Binding ManageMasteredCards}" />
                                            </StackPanel>
                                        </Border>
                                    </WrapPanel>

                                    <TextBlock FontSize="21" FontWeight="SemiBold" Text="Create or Edit Card" />
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid Grid.Column="0">
                                            <TextBox x:Name="CardFrontTextBox" Height="34" Text="{Binding CardFront, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Text="Card front">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource PlaceholderTextStyle}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Text, ElementName=CardFrontTextBox}" Value="">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                        <Grid Grid.Column="2">
                                            <TextBox x:Name="CardBackTextBox" Height="34" Text="{Binding CardBack, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Text="Card back">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource PlaceholderTextStyle}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Text, ElementName=CardBackTextBox}" Value="">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Grid>
                                    <Grid Margin="0,8,0,0">
                                        <TextBox x:Name="CardHintTextBox" Height="34" Text="{Binding CardHint, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="Hint (optional)">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource PlaceholderTextStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=CardHintTextBox}" Value="">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                    <Grid Margin="0,8,0,0">
                                        <TextBox x:Name="CardTagsTextBox" Height="34" Text="{Binding CardTagsText, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="Tags (comma separated)">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource PlaceholderTextStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=CardTagsTextBox}" Value="">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <Button Padding="12,6" Margin="0,0,8,0" Content="Save Card" Click="SaveCard_Click" />
                                        <Button Padding="12,6" Content="Cancel Edit" Click="ClearCardForm_Click" />
                                    </StackPanel>

                                    <TextBlock Margin="0,16,0,6" FontSize="21" FontWeight="SemiBold" Text="Quick Import" />
                                    <Grid>
                                        <TextBox x:Name="ImportRawTextBox" Height="88" AcceptsReturn="True" TextWrapping="Wrap" Text="{Binding ImportRawText, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="One card per line: front|back|hint|tag1,tag2" VerticalAlignment="Top" Margin="10,8,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource PlaceholderTextStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=ImportRawTextBox}" Value="">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <Button Padding="12,6" Margin="0,0,8,0" Content="Import Lines" Click="ImportCards_Click" />
                                        <TextBlock VerticalAlignment="Center" Foreground="#475569" Text="{Binding ImportResult}" />
                                    </StackPanel>

                                    <TextBlock Margin="0,16,0,6" FontSize="21" FontWeight="SemiBold" Text="Cards" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.5*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid Grid.Column="0">
                                            <TextBox x:Name="ManageCardQueryTextBox" Height="34" Text="{Binding ManageCardQuery, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Text="Search cards">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource PlaceholderTextStyle}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Text, ElementName=ManageCardQueryTextBox}" Value="">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                        <ComboBox Grid.Column="2" SelectedValuePath="Tag" SelectedValue="{Binding ManageCardFilter, UpdateSourceTrigger=PropertyChanged}">
                                            <ComboBoxItem Tag="all" Content="All" />
                                            <ComboBoxItem Tag="due" Content="Due" />
                                            <ComboBoxItem Tag="mastered" Content="Mastered" />
                                            <ComboBoxItem Tag="new" Content="New" />
                                        </ComboBox>
                                        <ComboBox Grid.Column="4" SelectedValuePath="Tag" SelectedValue="{Binding ManageCardSort, UpdateSourceTrigger=PropertyChanged}">
                                            <ComboBoxItem Tag="dueSoon" Content="Due soonest" />
                                            <ComboBoxItem Tag="frontAZ" Content="Front A-Z" />
                                            <ComboBoxItem Tag="recentReview" Content="Recently reviewed" />
                                            <ComboBoxItem Tag="streakDesc" Content="Highest streak" />
                                        </ComboBox>
                                    </Grid>

                                    <ListBox Margin="0,8,0,0" Height="290" ItemsSource="{Binding FilteredManageCards}" SelectedItem="{Binding ManageSelectedCard}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="0,0,0,6">
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding Front}" TextWrapping="Wrap" />
                                                    <TextBlock Margin="0,2,0,0" Text="{Binding Back}" TextWrapping="Wrap" />
                                                    <TextBlock Margin="0,2,0,0" Foreground="#64748B" Text="{Binding Hint, StringFormat=Hint: {0}}" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <Button Padding="12,6" Margin="0,0,8,0" Content="Edit Selected" Click="EditSelectedCard_Click" />
                                        <Button Padding="12,6" Content="Delete Selected" Click="DeleteSelectedCard_Click" />
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock FontSize="28" FontWeight="Bold" Text="Desktop Settings" />
                        <TextBlock Margin="0,6,0,14" Foreground="#475569" TextWrapping="Wrap" Text="Save API Base URL and Google Client ID once. The app will load these settings automatically on next run." />

                        <TextBlock FontWeight="SemiBold" Text="API Base URL" />
                        <Grid Margin="0,6,0,12">
                            <TextBox x:Name="SettingsApiBaseUrlTextBox" Height="36" VerticalContentAlignment="Center" Text="{Binding ApiBaseUrl, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="http://words-note.runasp.net">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource PlaceholderTextStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SettingsApiBaseUrlTextBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <TextBlock FontWeight="SemiBold" Text="Google OAuth Client ID" />
                        <Grid Margin="0,6,0,12">
                            <TextBox x:Name="SettingsGoogleClientIdTextBox" Height="36" VerticalContentAlignment="Center" Text="{Binding GoogleClientId, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Google OAuth Client ID">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource PlaceholderTextStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SettingsGoogleClientIdTextBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <StackPanel Orientation="Horizontal">
                            <Button Padding="14,6" Margin="0,0,8,0" Content="Save Settings" Click="SaveSettings_Click" />
                            <Button Padding="14,6" Content="Reload Data" Click="ReloadData_Click" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <Border Grid.Row="2" Margin="12,0,12,12" Padding="10" CornerRadius="10" BorderBrush="#D1D5DB" BorderThickness="1" Background="White">
            <DockPanel>
                <Button DockPanel.Dock="Right" Padding="12,6" Content="Logout" Click="Logout_Click" IsEnabled="{Binding IsAuthenticated}" />
                <TextBlock VerticalAlignment="Center" Text="WordsNote Desktop WPF - parity with frontend flows (Landing, Learn, Manage, Privacy)." />
            </DockPanel>
        </Border>
    </Grid>
</Window>
