<Window x:Class="WordsNote.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
        xmlns:conv="clr-namespace:WordsNote.Desktop.Converters"
        mc:Ignorable="d"
        Title="WordsNote Desktop (WPF)"
        Height="980"
        Width="1600"
        MinHeight="820"
        MinWidth="1280"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
    <Window.Resources>
        <SolidColorBrush x:Key="WnBg" po:Freeze="False" Color="#F7F3EC" />
        <SolidColorBrush x:Key="WnSurface" po:Freeze="False" Color="#FFFFFF" />
        <SolidColorBrush x:Key="WnSurfaceSoft" po:Freeze="False" Color="#FFF8EF" />
        <SolidColorBrush x:Key="WnBorder" po:Freeze="False" Color="#E6DFD3" />
        <SolidColorBrush x:Key="WnPanelBorder" po:Freeze="False" Color="#D1D5DB" />
        <SolidColorBrush x:Key="WnInk" po:Freeze="False" Color="#1F2333" />
        <SolidColorBrush x:Key="WnMuted" po:Freeze="False" Color="#5B6275" />
        <SolidColorBrush x:Key="WnPrimary" po:Freeze="False" Color="#1F4ED8" />
        <SolidColorBrush x:Key="WnPrimarySoft" po:Freeze="False" Color="#EDF2FF" />
        <SolidColorBrush x:Key="WnPrimaryHover" po:Freeze="False" Color="#1A43B8" />
        <SolidColorBrush x:Key="WnPrimaryPressed" po:Freeze="False" Color="#173A9C" />
        <SolidColorBrush x:Key="WnButtonBorder" po:Freeze="False" Color="#1639A5" />
        <SolidColorBrush x:Key="WnInfoBg" po:Freeze="False" Color="#EFF6FF" />
        <SolidColorBrush x:Key="WnInfoBorder" po:Freeze="False" Color="#BFDBFE" />
        <SolidColorBrush x:Key="WnStatusBusy" po:Freeze="False" Color="#0EA5E9" />
        <SolidColorBrush x:Key="WnSuccess" po:Freeze="False" Color="#0F766E" />
        <SolidColorBrush x:Key="WnPlaceholder" po:Freeze="False" Color="#94A3B8" />

        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBooleanConverter x:Key="InverseBool" />
        <conv:StringEqualsConverter x:Key="StringEquals" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource WnInk}" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource WnPrimary}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{DynamicResource WnButtonBorder}" />
            <Setter Property="BorderThickness" Value="1.2" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource WnPrimaryHover}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource WnPrimary}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource WnPrimaryPressed}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource WnPrimaryPressed}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ToggleButton">
            <Setter Property="Background" Value="{DynamicResource WnPrimarySoft}" />
            <Setter Property="Foreground" Value="{DynamicResource WnInk}" />
            <Setter Property="BorderBrush" Value="{DynamicResource WnPanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource WnPrimary}" />
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="{DynamicResource WnPrimary}" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="BorderBrush" Value="{DynamicResource WnButtonBorder}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource WnSurface}" />
            <Setter Property="Foreground" Value="{DynamicResource WnInk}" />
            <Setter Property="BorderBrush" Value="{DynamicResource WnBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Hidden" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Hidden" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource WnSurface}" />
            <Setter Property="Foreground" Value="{DynamicResource WnInk}" />
            <Setter Property="BorderBrush" Value="{DynamicResource WnBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Hidden" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Hidden" />
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource WnSurface}" />
            <Setter Property="Foreground" Value="{DynamicResource WnInk}" />
            <Setter Property="BorderBrush" Value="{DynamicResource WnBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Hidden" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Hidden" />
        </Style>

        <Style TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Hidden" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Hidden" />
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="0" />
            <Setter Property="Height" Value="0" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{DynamicResource WnSurface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource WnPanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid SnapsToDevicePixels="True" KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TabPanel Grid.Row="0"
                                      x:Name="HeaderPanel"
                                      IsItemsHost="True"
                                      Background="Transparent"
                                      Margin="0,0,0,1" />

                            <Border Grid.Row="1"
                                    Background="{DynamicResource WnSurface}"
                                    BorderBrush="{DynamicResource WnPanelBorder}"
                                    BorderThickness="1"
                                    CornerRadius="0,8,8,8">
                                <ContentPresenter x:Name="PART_SelectedContentHost"
                                                  Margin="{TemplateBinding Padding}"
                                                  ContentSource="SelectedContent" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="{DynamicResource WnSurfaceSoft}" />
            <Setter Property="Foreground" Value="{DynamicResource WnMuted}" />
            <Setter Property="BorderBrush" Value="{DynamicResource WnPanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Margin="0,0,3,0"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8,8,0,0"
                                SnapsToDevicePixels="True">
                            <ContentPresenter x:Name="HeaderContent"
                                              ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource WnSurfaceSoft}" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource WnPrimary}" />
                                <Setter Property="Foreground" Value="{DynamicResource WnInk}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource WnSurface}" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource WnPrimary}" />
                                <Setter Property="Foreground" Value="{DynamicResource WnInk}" />
                                <Setter Property="Panel.ZIndex" Value="100" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="{DynamicResource WnSurface}" />
            <Setter Property="Foreground" Value="{DynamicResource WnInk}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource WnSurfaceSoft}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource WnPrimarySoft}" />
                    <Setter Property="Foreground" Value="{DynamicResource WnInk}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource WnPanelBorder}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{DynamicResource WnSurface}" />
            <Setter Property="Foreground" Value="{DynamicResource WnInk}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{DynamicResource WnSurfaceSoft}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource WnPrimarySoft}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource WnPanelBorder}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PlaceholderTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource WnPlaceholder}" />
            <Setter Property="Margin" Value="10,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource WnBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="12" Padding="12" CornerRadius="12" BorderBrush="{DynamicResource WnPanelBorder}" BorderThickness="1" Background="{DynamicResource WnSurface}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Margin="0,0,12,0" Padding="16,7" Content="Reload Data" Click="ReloadData_Click" />

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock VerticalAlignment="Center" Margin="0,0,8,0" Text="{Binding StatusMessage}" Foreground="{DynamicResource WnInk}" />
                    <TextBlock VerticalAlignment="Center" FontWeight="Bold" Foreground="{DynamicResource WnStatusBusy}" Text="{Binding IsBusy, StringFormat=Busy: {0}}" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="12,0,12,12" SelectedIndex="{Binding SelectedTabIndex}">
            <TabItem Header="Landing">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20" Orientation="Vertical">
                        <TextBlock FontSize="13" Foreground="{DynamicResource WnMuted}" Text="WordsNote Studio" />
                        <TextBlock Margin="0,8,0,8" FontSize="34" FontWeight="Bold" Text="Learn in a way that feels handcrafted." />
                        <TextBlock FontSize="16" Foreground="{DynamicResource WnInk}" TextWrapping="Wrap" Text="Desktop app mirrors web features: Learn (Flashcards/Learn/Practice), Manage collections and cards in local/cloud mode, and bilingual Privacy policy." />

                        <Border Margin="0,20,0,0" Padding="16" CornerRadius="10" Background="{DynamicResource WnInfoBg}" BorderBrush="{DynamicResource WnInfoBorder}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock FontSize="20" FontWeight="SemiBold" Text="Quick Start" />
                                <TextBlock Margin="0,10,0,0" TextWrapping="Wrap" Text="1. Open Settings and save API Base URL (required). Google Client ID is already preconfigured for optional cloud login." />
                                <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Text="2. Use Manage immediately in local mode (no account required)." />
                                <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Text="3. Use Learn for public study modes (Flashcards, Learn, Practice)." />
                                <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Text="4. Optional cloud sync: login with Google and use Sync Local -> Cloud." />
                                <WrapPanel Margin="0,12,0,0" ItemHeight="34" ItemWidth="170">
                                    <Button Margin="0,0,8,8" Content="Open Settings" Click="OpenSettingsFromLanding_Click" />
                                    <Button Margin="0,0,8,8" Content="Open Learn" Click="OpenLearnFromLanding_Click" />
                                    <Button Margin="0,0,8,8" Content="Open Manage" Click="OpenManageFromLanding_Click" />
                                    <Button Margin="0,0,8,8" Content="Open Login Page" Click="OpenLoginFromLanding_Click" />
                                    <Button Margin="0,0,8,8" Content="Privacy Policy" Click="OpenPrivacyFromLanding_Click" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Learn">
                <Grid Margin="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Padding="12" BorderBrush="{DynamicResource WnPanelBorder}" BorderThickness="1" CornerRadius="10" Background="{DynamicResource WnSurface}">
                        <StackPanel>
                            <TextBlock FontSize="22" FontWeight="SemiBold" Text="Decks" />
                            <TextBlock Margin="0,4,0,10" Foreground="{DynamicResource WnMuted}" Text="Public dynamic collections from backend" />
                            <ListBox Height="650"
                                     ItemsSource="{Binding Decks}"
                                     SelectedItem="{Binding LearnSelectedDeck}"
                                     DisplayMemberPath="Title" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Padding="14" BorderBrush="{DynamicResource WnPanelBorder}" BorderThickness="1" CornerRadius="10" Background="{DynamicResource WnSurface}">
                        <StackPanel>
                            <TextBlock FontSize="26" FontWeight="Bold" Text="Learn Lab" />
                            <TextBlock Margin="0,4,0,8" Foreground="{DynamicResource WnMuted}" Text="Modes: Flashcards, Learn (typed answer), Practice (multiple choice)" />
                            <TextBlock FontSize="15" FontWeight="SemiBold" Text="{Binding LearnSelectedDeck.Title, StringFormat=Collection: {0}}" />

                            <StackPanel Margin="0,10,0,12" Orientation="Horizontal">
                                <Button Padding="14,6" Margin="0,0,8,0" Content="Flashcards" Click="LearnFlashMode_Click" />
                                <Button Padding="14,6" Margin="0,0,8,0" Content="Learn" Click="LearnTypeMode_Click" />
                                <Button Padding="14,6" Content="Practice" Click="LearnPracticeMode_Click" />
                            </StackPanel>

                            <Border Padding="14" BorderBrush="{DynamicResource WnPanelBorder}" BorderThickness="1" CornerRadius="10" Background="{DynamicResource WnSurfaceSoft}">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource WnInk}" Text="{Binding LearnDisplayIndex, StringFormat=Card {0}}" />
                                    <TextBlock Foreground="{DynamicResource WnMuted}" Text="{Binding LearnCardCount, StringFormat=Total cards in mode: {0}}" />

                                    <StackPanel Margin="0,12,0,0" Visibility="{Binding LearnMode, Converter={StaticResource StringEquals}, ConverterParameter=flash}">
                                        <TextBlock FontSize="26" FontWeight="Bold" TextWrapping="Wrap" Text="{Binding LearnCurrentCard.Front}" />
                                        <TextBlock Margin="0,10,0,0" FontSize="20" TextWrapping="Wrap" Foreground="{DynamicResource WnSuccess}" Text="{Binding LearnCurrentCard.Back}" Visibility="{Binding LearnShowBack, Converter={StaticResource BoolToVis}}" />
                                        <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource WnMuted}" Text="Click Flip to reveal answer" Visibility="{Binding LearnShowBack, Converter={StaticResource InverseBool}}" />
                                        <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource WnMuted}" Text="{Binding LearnCurrentCard.Hint, StringFormat=Hint: {0}}" />

                                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                            <Button Padding="12,6" Margin="0,0,8,0" Content="Previous" Click="LearnPrevious_Click" />
                                            <Button Padding="12,6" Margin="0,0,8,0" Content="Flip" Click="LearnFlip_Click" />
                                            <Button Padding="12,6" Content="Next" Click="LearnNext_Click" />
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Margin="0,12,0,0" Visibility="{Binding IsLearnTypingMode, Converter={StaticResource BoolToVis}}">
                                        <TextBlock FontSize="24" FontWeight="Bold" TextWrapping="Wrap" Text="{Binding LearnCurrentCard.Front}" />
                                        <Grid Margin="0,10,0,0">
                                            <TextBox x:Name="LearnTypedAnswerTextBox" Height="38" VerticalContentAlignment="Center" Text="{Binding LearnTypedAnswer, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Text="Type your answer here">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource PlaceholderTextStyle}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Text, ElementName=LearnTypedAnswerTextBox}" Value="">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                            <Button Padding="14,6" Margin="0,0,8,0" Content="Check" Click="LearnCheckTyping_Click" />
                                            <Button Padding="14,6" Content="Skip" Click="LearnNext_Click" />
                                        </StackPanel>
                                        <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" Text="{Binding LearnFeedback}" Foreground="{DynamicResource WnInk}" />
                                    </StackPanel>

                                    <StackPanel Margin="0,12,0,0" Visibility="{Binding IsLearnPracticeMode, Converter={StaticResource BoolToVis}}">
                                        <TextBlock FontSize="24" FontWeight="Bold" TextWrapping="Wrap" Text="{Binding LearnCurrentCard.Front}" />
                                        <TextBlock Margin="0,8,0,4" Text="Choose the correct answer" />
                                        <ListBox Height="180" ItemsSource="{Binding LearnPracticeOptions}" SelectedItem="{Binding SelectedPracticeOption}" />
                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                            <Button Padding="14,6" Margin="0,0,8,0" Content="Submit" Click="LearnSubmitPractice_Click" />
                                            <Button Padding="14,6" Content="Next" Click="LearnNextPractice_Click" IsEnabled="{Binding LearnPracticeAwaitingNext}" />
                                        </StackPanel>
                                        <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" Text="{Binding LearnPracticeFeedback}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Privacy" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <Button Padding="12,6" Width="160" HorizontalAlignment="Left" Margin="0,0,0,12" Content="Back to Landing" Click="BackToLandingFromPrivacy_Click" />
                        <TextBlock FontSize="30" FontWeight="Bold" Text="{Binding PrivacyTitle}" />
                        <TextBlock Margin="0,6,0,12" FontSize="15" Foreground="{DynamicResource WnMuted}" TextWrapping="Wrap" Text="{Binding PrivacySubtitle}" />

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Button Padding="12,6" Margin="0,0,8,0" Content="VI" Click="PrivacyVi_Click" />
                            <Button Padding="12,6" Content="EN" Click="PrivacyEn_Click" />
                        </StackPanel>

                        <TextBox Height="620"
                                 FontSize="14"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding PrivacyPolicyText, Mode=OneWay}" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Manage">
                <Grid Margin="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="340" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Padding="12" BorderBrush="{DynamicResource WnPanelBorder}" BorderThickness="1" CornerRadius="10" Background="{DynamicResource WnSurface}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <Expander Header="Create Collection" IsExpanded="False">
                                        <StackPanel Margin="0,8,0,0">
                                            <Grid Margin="0,0,0,8">
                                                <TextBox x:Name="NewCollectionTitleTextBox" Height="36" Text="{Binding NewCollectionTitle, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Text="Collection title">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource PlaceholderTextStyle}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Text, ElementName=NewCollectionTitleTextBox}" Value="">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                            <Grid Margin="0,0,0,10">
                                                <TextBox x:Name="NewCollectionDescriptionTextBox" Height="70" TextWrapping="Wrap" AcceptsReturn="True" Text="{Binding NewCollectionDescription, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Text="Collection description" VerticalAlignment="Top" Margin="10,8,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource PlaceholderTextStyle}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Text, ElementName=NewCollectionDescriptionTextBox}" Value="">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                            <Button Padding="12,7" Content="Create" Click="CreateCollection_Click" />
                                        </StackPanel>
                                    </Expander>

                                    <Separator Margin="0,14,0,12" />

                                    <TextBlock FontSize="22" FontWeight="SemiBold" Text="Your Collections" />
                                    <Grid Margin="0,8,0,8">
                                        <TextBox x:Name="ManageCollectionQueryTextBox" Height="34" Text="{Binding ManageCollectionQuery, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="Search collections">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource PlaceholderTextStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=ManageCollectionQueryTextBox}" Value="">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                    <ComboBox Margin="0,0,0,10" SelectedValuePath="Tag" SelectedValue="{Binding ManageCollectionSort, UpdateSourceTrigger=PropertyChanged}">
                                        <ComboBoxItem Tag="recent" Content="Recently updated" />
                                        <ComboBoxItem Tag="title" Content="Title A-Z" />
                                        <ComboBoxItem Tag="cards" Content="Most cards" />
                                    </ComboBox>

                                    <ListBox Height="510" ItemsSource="{Binding FilteredManageDecks}" SelectedItem="{Binding ManageSelectedDeck}" DisplayMemberPath="Title" />
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <Border Grid.Column="2" Padding="12" BorderBrush="{DynamicResource WnPanelBorder}" BorderThickness="1" CornerRadius="10" Background="{DynamicResource WnSurface}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock FontSize="26" FontWeight="Bold" Text="{Binding ManageSelectedDeck.Title}" />
                                    <TextBlock Margin="0,4,0,8" Foreground="{DynamicResource WnMuted}" TextWrapping="Wrap" Text="{Binding ManageSelectedDeck.Description}" />

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Button Padding="12,6" Margin="0,0,8,0" Content="Edit Collection" Click="StartCollectionEdit_Click" />
                                        <Button Padding="12,6" Margin="0,0,8,0" Content="Delete Collection" Click="DeleteCollection_Click" />
                                        <ToggleButton x:Name="CardToolsToggleButton" Content="Card Tools" IsThreeState="False" IsChecked="{Binding IsExpanded, ElementName=CardToolsExpander, Mode=TwoWay}" />
                                    </StackPanel>

                                    <Border Padding="10" Margin="0,0,0,10" BorderBrush="{DynamicResource WnPanelBorder}" BorderThickness="1" CornerRadius="8" Background="{DynamicResource WnSurfaceSoft}" Visibility="{Binding IsEditingCollection, Converter={StaticResource BoolToVis}}">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="Edit Collection" />
                                            <Grid Margin="0,8,0,8">
                                                <TextBox x:Name="EditCollectionTitleTextBox" Height="34" Text="{Binding EditCollectionTitle, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Text="Edit collection title">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource PlaceholderTextStyle}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Text, ElementName=EditCollectionTitleTextBox}" Value="">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                            <Grid Margin="0,0,0,10">
                                                <TextBox x:Name="EditCollectionDescriptionTextBox" Height="66" TextWrapping="Wrap" AcceptsReturn="True" Text="{Binding EditCollectionDescription, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Text="Edit collection description" VerticalAlignment="Top" Margin="10,8,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource PlaceholderTextStyle}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Text, ElementName=EditCollectionDescriptionTextBox}" Value="">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Padding="12,6" Margin="0,0,8,0" Content="Save" Click="SaveCollectionEdit_Click" />
                                                <Button Padding="12,6" Content="Cancel" Click="CancelCollectionEdit_Click" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <WrapPanel Margin="0,0,0,10">
                                        <Border Width="170" Margin="0,0,8,0" Padding="8" BorderBrush="{DynamicResource WnPanelBorder}" BorderThickness="1" CornerRadius="8" Background="{DynamicResource WnSurfaceSoft}">
                                            <StackPanel>
                                                <TextBlock Foreground="{DynamicResource WnMuted}" Text="Total cards" />
                                                <TextBlock FontSize="24" FontWeight="Bold" Text="{Binding ManageTotalCards}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Width="170" Margin="0,0,8,0" Padding="8" BorderBrush="{DynamicResource WnPanelBorder}" BorderThickness="1" CornerRadius="8" Background="{DynamicResource WnSurfaceSoft}">
                                            <StackPanel>
                                                <TextBlock Foreground="{DynamicResource WnMuted}" Text="Due now" />
                                                <TextBlock FontSize="24" FontWeight="Bold" Text="{Binding ManageDueCards}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Width="170" Padding="8" BorderBrush="{DynamicResource WnPanelBorder}" BorderThickness="1" CornerRadius="8" Background="{DynamicResource WnSurfaceSoft}">
                                            <StackPanel>
                                                <TextBlock Foreground="{DynamicResource WnMuted}" Text="Mastered" />
                                                <TextBlock FontSize="24" FontWeight="Bold" Text="{Binding ManageMasteredCards}" />
                                            </StackPanel>
                                        </Border>
                                    </WrapPanel>

                                    <Expander x:Name="CardToolsExpander" Header="Card Editor + Quick Import" IsExpanded="False" Margin="0,0,0,12">
                                        <StackPanel Margin="0,8,0,0">
                                            <TextBlock FontSize="21" FontWeight="SemiBold" Text="Create Card" />
                                            <Grid Margin="0,8,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid Grid.Column="0">
                                                    <TextBox x:Name="CardFrontTextBox" Height="34" Text="{Binding CardFront, UpdateSourceTrigger=PropertyChanged}" />
                                                    <TextBlock Text="Card front">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock" BasedOn="{StaticResource PlaceholderTextStyle}">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Text, ElementName=CardFrontTextBox}" Value="">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                                <Grid Grid.Column="2">
                                                    <TextBox x:Name="CardBackTextBox" Height="34" Text="{Binding CardBack, UpdateSourceTrigger=PropertyChanged}" />
                                                    <TextBlock Text="Card back">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock" BasedOn="{StaticResource PlaceholderTextStyle}">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Text, ElementName=CardBackTextBox}" Value="">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Grid>
                                            <Grid Margin="0,8,0,0">
                                                <TextBox x:Name="CardHintTextBox" Height="34" Text="{Binding CardHint, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Text="Hint (optional)">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource PlaceholderTextStyle}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Text, ElementName=CardHintTextBox}" Value="">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                            <Grid Margin="0,8,0,0">
                                                <TextBox x:Name="CardTagsTextBox" Height="34" Text="{Binding CardTagsText, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Text="Tags (comma separated)">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource PlaceholderTextStyle}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Text, ElementName=CardTagsTextBox}" Value="">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                <Button Padding="12,6" Margin="0,0,8,0" Content="Add Card" Click="SaveCard_Click" />
                                                <Button Padding="12,6" Content="Clear" Click="ClearCardForm_Click" />
                                            </StackPanel>

                                            <TextBlock Margin="0,16,0,6" FontSize="21" FontWeight="SemiBold" Text="Quick Import" />
                                            <Grid>
                                                <TextBox x:Name="ImportRawTextBox" Height="88" AcceptsReturn="True" TextWrapping="Wrap" Text="{Binding ImportRawText, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Text="One card per line: front|back|hint|tag1,tag2" VerticalAlignment="Top" Margin="10,8,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource PlaceholderTextStyle}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Text, ElementName=ImportRawTextBox}" Value="">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                <Button Padding="12,6" Margin="0,0,8,0" Content="Import Lines" Click="ImportCards_Click" />
                                                <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource WnMuted}" Text="{Binding ImportResult}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Expander>

                                    <TextBlock Margin="0,16,0,6" FontSize="21" FontWeight="SemiBold" Text="Cards" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.5*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid Grid.Column="0">
                                            <TextBox x:Name="ManageCardQueryTextBox" Height="34" Text="{Binding ManageCardQuery, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Text="Search cards">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource PlaceholderTextStyle}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Text, ElementName=ManageCardQueryTextBox}" Value="">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                        <ComboBox Grid.Column="2" SelectedValuePath="Tag" SelectedValue="{Binding ManageCardFilter, UpdateSourceTrigger=PropertyChanged}">
                                            <ComboBoxItem Tag="all" Content="All" />
                                            <ComboBoxItem Tag="due" Content="Due" />
                                            <ComboBoxItem Tag="mastered" Content="Mastered" />
                                            <ComboBoxItem Tag="new" Content="New" />
                                        </ComboBox>
                                        <ComboBox Grid.Column="4" SelectedValuePath="Tag" SelectedValue="{Binding ManageCardSort, UpdateSourceTrigger=PropertyChanged}">
                                            <ComboBoxItem Tag="dueSoon" Content="Due soonest" />
                                            <ComboBoxItem Tag="frontAZ" Content="Front A-Z" />
                                            <ComboBoxItem Tag="recentReview" Content="Recently reviewed" />
                                            <ComboBoxItem Tag="streakDesc" Content="Highest streak" />
                                        </ComboBox>
                                    </Grid>

                                    <ListBox Margin="0,8,0,0" Height="290" ItemsSource="{Binding FilteredManageCards}" SelectedItem="{Binding ManageSelectedCard}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="0,0,0,6">
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding Front}" TextWrapping="Wrap" />
                                                    <TextBlock Margin="0,2,0,0" Text="{Binding Back}" TextWrapping="Wrap" />
                                                    <TextBlock Margin="0,2,0,0" Foreground="{DynamicResource WnMuted}" Text="{Binding Hint, StringFormat=Hint: {0}}" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <Button Padding="12,6" Margin="0,0,8,0" Content="Edit Selected" Click="EditSelectedCard_Click" />
                                        <Button Padding="12,6" Content="Delete Selected" Click="DeleteSelectedCard_Click" />
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock FontSize="28" FontWeight="Bold" Text="Desktop Settings" />
                        <TextBlock Margin="0,6,0,14" Foreground="{DynamicResource WnMuted}" TextWrapping="Wrap" Text="Save API Base URL once. Google login client ID is preconfigured in app runtime settings." />

                        <TextBlock FontWeight="SemiBold" Text="API Base URL" />
                        <Grid Margin="0,6,0,12">
                            <TextBox x:Name="SettingsApiBaseUrlTextBox" Height="36" VerticalContentAlignment="Center" Text="{Binding ApiBaseUrl, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="http://words-note.runasp.net">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource PlaceholderTextStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SettingsApiBaseUrlTextBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <TextBlock Margin="0,0,0,12" Foreground="{DynamicResource WnMuted}" TextWrapping="Wrap" Text="Google OAuth Client ID is preconfigured in app runtime settings for optional cloud login." />

                        <TextBlock FontWeight="SemiBold" Text="Theme" />
                        <StackPanel Margin="0,6,0,12" Orientation="Horizontal" VerticalAlignment="Center">
                            <ComboBox Width="230" SelectedValuePath="Tag" SelectedValue="{Binding ThemeMode, UpdateSourceTrigger=PropertyChanged}" SelectionChanged="ThemeMode_SelectionChanged">
                                <ComboBoxItem Tag="light" Content="Light - Warm Paper" />
                                <ComboBoxItem Tag="dark" Content="Dark - Night Ink" />
                            </ComboBox>
                            <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource WnMuted}" Text="Theme màu gần FE, áp dụng ngay khi đổi." />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <Button Padding="14,6" Margin="0,0,8,0" Content="Save Settings" Click="SaveSettings_Click" />
                            <Button Padding="14,6" Content="Reload Data" Click="ReloadData_Click" />
                        </StackPanel>

                        <Border Margin="0,14,0,0" Padding="12" BorderBrush="{DynamicResource WnPanelBorder}" BorderThickness="1" CornerRadius="10" Background="{DynamicResource WnSurfaceSoft}">
                            <StackPanel>
                                <TextBlock FontSize="20" FontWeight="SemiBold" Text="Cloud and Sync Quick Actions" />
                                <TextBlock Margin="0,4,0,8" Foreground="{DynamicResource WnMuted}" Text="{Binding ManageModeLabel}" />
                                <TextBlock Margin="0,0,0,8" Foreground="{DynamicResource WnInk}" TextWrapping="Wrap" Text="Khi chưa login: thao tác chỉ lưu local trên máy. Khi login Google: thao tác đi cloud. Có cả Sync Local -> Cloud và Sync Cloud -> Local như extension." />

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button Padding="14,6" Margin="0,0,8,0" Content="Sync Cloud -> Local" Click="SyncCloudToLocal_Click" />
                                    <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource WnMuted}" Text="Load cloud data and save into local storage" />
                                </StackPanel>

                                <StackPanel Visibility="{Binding IsNotAuthenticated, Converter={StaticResource BoolToVis}}">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Button Padding="14,6" Content="Go to Login Page" Click="OpenLoginFromManage_Click" />
                                        <TextBlock VerticalAlignment="Center" Margin="8,0,0,0" Foreground="{DynamicResource WnMuted}" Text="Manage local is available without login. Cloud actions require Login page." />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVis}}">
                                    <Button Padding="14,6" Margin="0,0,8,0" Content="Sync Local -> Cloud" Click="SyncLocalToCloud_Click" IsEnabled="{Binding CanSyncLocalToCloud}" />
                                    <Button Padding="14,6" Margin="0,0,8,0" Content="Logout Google" Click="Logout_Click" />
                                    <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource WnMuted}" Text="{Binding LastSyncMessage}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Login">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock FontSize="28" FontWeight="Bold" Text="Login" />
                        <TextBlock Margin="0,6,0,8" Foreground="{DynamicResource WnMuted}" TextWrapping="Wrap" Text="Google login is optional for cloud mode. Local mode in Manage and Learn works without authentication." />
                        <Border Margin="0,0,0,12" Padding="10" CornerRadius="8" BorderBrush="{DynamicResource WnInfoBorder}" BorderThickness="1" Background="{DynamicResource WnInfoBg}">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="Certification test path (no account required)" />
                                <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Text="Open Manage to create/edit local collections/cards and open Learn to test Flashcards/Learn/Practice." />
                            </StackPanel>
                        </Border>

                        <StackPanel Visibility="{Binding IsNotAuthenticated, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Button Padding="14,6" Content="Login Google (Browser)" Click="LoginWithGoogleBrowser_Click" IsEnabled="{Binding HasGoogleClientId}" />
                                <TextBlock VerticalAlignment="Center" Margin="8,0,0,0" Foreground="{DynamicResource WnMuted}" Text="Uses built-in Google Client ID (optional cloud login)" />
                            </StackPanel>

                            <TextBlock Margin="0,0,0,10" Foreground="{DynamicResource WnMuted}" TextWrapping="Wrap" Visibility="{Binding HasGoogleClientId, Converter={StaticResource InverseBool}}" Text="Google Client ID is not configured. This only affects optional cloud login. You can continue with Local mode now." />

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Button Padding="14,6" Margin="0,0,8,0" Content="Continue in Local Mode" Click="ContinueLocalMode_Click" />
                                <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource WnMuted}" Text="Go to Manage without login" />
                            </StackPanel>

                            <TextBlock Foreground="{DynamicResource WnMuted}" TextWrapping="Wrap" Text="ID token manual login is removed from end-user UI to keep certification test path simple and local-first." />
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVis}}">
                            <TextBlock Foreground="{DynamicResource WnSuccess}" Margin="0,0,0,8" Text="You are logged in. Manage tab is now in cloud mode." />
                            <StackPanel Orientation="Horizontal">
                                <Button Padding="14,6" Margin="0,0,8,0" Content="Go to Manage" Click="OpenManageFromLogin_Click" />
                                <Button Padding="14,6" Content="Logout Google" Click="Logout_Click" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <Border Grid.Row="2" Margin="12,0,12,12" Padding="10" CornerRadius="10" BorderBrush="{DynamicResource WnPanelBorder}" BorderThickness="1" Background="{DynamicResource WnSurface}">
            <DockPanel>
                <Button DockPanel.Dock="Right" Padding="12,6" Content="Logout" Click="Logout_Click" IsEnabled="{Binding IsAuthenticated}" />
                <TextBlock VerticalAlignment="Center" Text="WordsNote Desktop WPF - parity with frontend flows (Landing, Learn, Manage, Privacy)." />
            </DockPanel>
        </Border>
    </Grid>
</Window>
